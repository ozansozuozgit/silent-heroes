{
  "name": "silent-heroes",
  "private": true,
  "version": "0.1.0",
  "description": "Find under-credited contributors in any public GitHub repo and give their quiet work a recognition moment. Local-first, no backend.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/ozansozuoz/silent-heroes",
  "repository": {
    "type": "git",
    "url": "https://github.com/ozansozuoz/silent-heroes.git"
  },
  "keywords": [
    "github",
    "open-source",
    "contributors",
    "recognition",
    "attribution",
    "maintainers",
    "react",
    "vite"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.1.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "7.3.1",
    "vitest": "3.2.4"
  }
}
