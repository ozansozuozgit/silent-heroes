{
  "name": "Silent Heroes",
  "short_name": "Silent Heroes",
  "description": "Find under-credited contributors in public GitHub repos and give their quiet work a moment.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#fbfbfa",
